# Doubao ARK (OpenAI-compatible)
DOUBAO_API_KEY=replace-me
# Optional model overrides
# DOUBAO_MODEL_PRO=ep-...
# DOUBAO_MODEL_STD=ep-...
# DOUBAO_MODEL_LITE=ep-...

# Turso (production). Leave blank for local sqlite file.
# TURSO_URL=libsql://...
# TURSO_TOKEN=...

# Daytona real container (required for run_command / run_python; no mock fallback)
DAYTONA_API_KEY=dtn_...
# DAYTONA_API_URL=https://app.daytona.io/api
